{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the HomeCal application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has premium features enabled."
        },
        "lastGreetingDate": {
          "type": "string",
          "description": "The date (YYYY-MM-DD) the user was last greeted."
        },
        "webAuthnCredentialId": {
          "type": "string",
          "description": "The credential ID for biometric (face) login."
        },
        "webAuthnPublicKey": {
          "type": "string",
          "description": "The public key for biometric login."
        }
      },
      "required": ["uid", "email"]
    },
    "Event": {
      "title": "Event",
      "description": "A calendar appointment or event.",
      "type": "object",
      "properties": {
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who created the event."
        },
        "title": {
          "type": "string",
          "description": "The title of the event."
        },
        "description": {
          "type": "string",
          "description": "A description of the event."
        },
        "startTime": {
          "type": "timestamp",
          "description": "The start time of the event."
        },
        "endTime": {
          "type": "timestamp",
          "description": "The end time of the event."
        },
        "sharedWith": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "email"
          },
          "description": "A list of email addresses this event is shared with."
        }
      },
      "required": ["ownerId", "title", "startTime", "endTime"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and settings."
    },
    "/events/{eventId}": {
      "schema": {
        "$ref": "#/entities/Event"
      },
      "description": "Stores calendar events."
    }
  }
}
